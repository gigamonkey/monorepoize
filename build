#!/bin/bash

set -e

case "$1" in
    -h|-help|--help)
        cat <<EOF
Build a monorepo from multiple existing repos.

Usage: build [--sync=MODE] REPOSFILE [DEFAULT_BRANCH]

REPOSFILE should be named foo.repos where foo is the name of the directory to
build the monoropo in and should contain either github URLs or paths to bare
repo's .git directories, one per line.

BRANCH is the branch name that will be created as the main branch in the mono
repo. Defaults to 'main'. All other branches from incorporated repos will be
mapped to new branchs in the monorepo.

--sync=MODE sets how later upstream commits are folded back in by \`update\`:
'replay' (default) replays them onto the subdir, 'merge' subtree-merges them so
the monorepo side can also change the subdir. It can be changed later per repo
with \`update --merge\`.

EOF
        exit 0
        ;;
esac

# Parse a leading --sync=MODE flag; everything else stays positional.
SYNC=replay
posargs=()
for a in "$@"; do
    case "$a" in
        --sync=*) SYNC="${a#*=}" ;;
        *) posargs+=("$a") ;;
    esac
done
set -- "${posargs[@]}"
case "$SYNC" in merge|replay) ;; *) echo "Invalid --sync mode: $SYNC (want merge or replay)" >&2; exit 1 ;; esac

source "$(dirname $0)/monorepo.sh"

here=$(pwd)
input=$(realpath "$1")
branch=${2:-main}

ensure_repo_dir "$(basename "$1" .repos)"

sources=""
while read -r repo; do
    # Accept either github URLs or a path to a bare repo .git directory.
    if [ "${repo:0:15}" != "git@github.com:" ]; then
        repo=$(cd "$here"; realpath "$repo")
    fi
    name=${repo##*/}
    name=${name%.git}
    echo "Incorporating $name ..."
    incorporate "$name" "$repo"
    sources+="$name $repo"$'\n'
done < "$input"

pushdown "$branch"

# Record where each repo came from so `update` can pull later upstream commits.
printf '%s' "$sources" | while read -r name repo; do
    [ -n "$name" ] && stage_source "$name" "$repo"
done

# In merge mode, mark each repo and record its initial integration point (the
# upstream tip that main was just built from) so `update` can subtree-merge
# later commits from a correct base.
if [ "$SYNC" = merge ]; then
    printf '%s' "$sources" | while read -r name repo; do
        [ -n "$name" ] || continue
        if git show-ref --verify --quiet "refs/heads/$name/$branch"; then
            stage_mode "$name" merge
            stage_synced "$name" "$(git rev-parse "refs/heads/$name/$branch")"
        fi
    done
fi
git commit -q -m "Record source URLs."
