#!/bin/bash

set -e

# Parse a leading --sync=MODE flag; everything else stays positional.
SYNC=replay
posargs=()
for a in "$@"; do
    case "$a" in
        --sync=*) SYNC="${a#*=}" ;;
        *) posargs+=("$a") ;;
    esac
done
set -- "${posargs[@]}"
case "$SYNC" in merge|replay) ;; *) echo "Invalid --sync mode: $SYNC (want merge or replay)" >&2; exit 1 ;; esac

source "$(dirname $0)/monorepo.sh"

here=$(pwd)

repo="$1"
branch=${2:-main}

# Assume we are already in the repository we are adding to.

# Accept either github URLs or a path to a bare repo .git directory.
if [ "${repo:0:15}" != "git@github.com:" ]; then
    repo=$(cd "$here"; realpath "$repo")
fi
name=${repo##*/}
name=${name%.git}
echo "Incorporating $name ..."

incorporate "$name" "$repo"
pushdown_one "$branch" "$name/$branch"

# Record where this repo came from so `update` can pull later upstream commits.
git switch "$branch"
stage_source "$name" "$repo"

# In merge mode, mark the repo and record its initial integration point (the
# upstream tip just merged in) so `update` can subtree-merge later commits.
if [ "$SYNC" = merge ] && git show-ref --verify --quiet "refs/heads/$name/$branch"; then
    stage_mode "$name" merge
    stage_synced "$name" "$(git rev-parse "refs/heads/$name/$branch")"
fi
git commit -q -m "Record source URL for $name."
